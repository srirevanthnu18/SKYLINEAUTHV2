SECRET_KEY=your-secret-key-here
DATABASE_NAME=SKYLINE
DB_DRIVER=mongo
# Example Mongo URI (SRV)
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxxx.mongodb.net/SKYLINE?retryWrites=true&w=majority&appName=Cluster0

# ── Discord Bot Settings ────────────────────────────────────────────
# Get token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Your Discord user ID (Developer Mode → right-click name → Copy ID)
DISCORD_OWNER_ID=your_discord_user_id_here

# Flask backend URL (used by the bot to call management API)
SERVER_URL=https://your-app.onrender.com

# Shared secret between bot and Flask server (make this long & random)
MGMT_SECRET=change_me_to_a_long_random_string

# MongoDB ObjectId of the default app and package for Discord user creation
# Find these in your dashboard: /apps/manage/<APP_ID>  and  /packages
DISCORD_APP_ID=your_app_objectid_here
DISCORD_PACKAGE_ID=your_package_objectid_here

